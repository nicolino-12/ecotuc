# CONFIGURACIÓN DEL PROYECTO ECOTUC

# --- FRONTEND (Next.js) ---
# URL de conexión a la API
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- BACKEND ---
# Puerto del servidor
PORT=3001
# URL de la base de datos (si se usa MongoDB, PostgreSQL, etc. en producción)
DATABASE_URL=mongodb://localhost:27017/ecotuc
